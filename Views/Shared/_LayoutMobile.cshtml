@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - ECRS</title>

    <link rel="icon" href="~/inc/img/favicon.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- 你專案既有樣式 -->
    <link rel="stylesheet" href="~/inc/css/icomoon/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/inc/plugin/bootstrap-select/css/bootstrap-select.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/inc/plugin/owl-carousel/owl.carousel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/inc/css/cf-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/inc/css/animate.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pmds-overrides.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        .pmds-navbar { background: darkgreen; }
        .pmds-navbar .navbar-brand, .pmds-navbar .nav-link, .pmds-navbar .navbar-text { color:#fff !important; }

        .pmds-sidebar {
            background: darkgreen;
            color:#fff;
            border-right: 1px solid rgba(255,255,255,.15);
        }
        .pmds-sidebar a, .pmds-sidebar span, .pmds-sidebar li { color:#fff; }
        .pmds-sidebar > ul { background: rgba(255,255,255,0.12); padding: 12px; border-radius: 8px; }

        .pmds-submenu {
            margin: 8px 0 0 0;
            padding: 6px 0 0 12px;
            border-left: 2px solid rgba(255,255,255,.18);
        }
        .pmds-submenu > li > a{
            display:block; padding:10px 12px; margin:6px 10px 6px 0;
            border-radius:6px; color:rgba(255,255,255,.92);
            text-decoration:none;
        }
        .pmds-submenu > li > a:hover { background: rgba(255,255,255,.14); color:#fff; }
        .pmds-submenu > li.active > a { background: rgba(255,255,255,.24); font-weight:600; }

        .pmds-footer{
            font-size:10pt; background:darkgreen; color:#fff;
            padding: 12px 0;
        }
    </style>
</head>

<body class="bg-light">
    @{
        // ===== Route 判斷（沿用你 _Layout.cshtml 的邏輯）=====
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isInspection = currentController == "Inspection";
        var isInspectionWork = isInspection && currentAction == "InspectionQry";
        var isInspectionVendor = isInspection && currentAction == "Fquery";
        var isInspectionCase = isInspection && currentAction == "FormQuery";

        var isPReview = currentController == "PReview";
        var isInspectionPReview = isInspection && currentAction == "PReview";

        var isFormManage = currentController == "FormManage";
        var isFormManageFormEditer = isFormManage && currentAction == "FormEditer";
        var isFormManageFormQryByPJ = isFormManage && currentAction == "FormQryByPJ";

        // ===== Session 內的登入資訊 =====
        var token = HttpContextAccessor.HttpContext?.Session.GetString("AuthToken");
        var displayName = HttpContextAccessor.HttpContext?.Session.GetString("DisplayName");
    }

    <!-- Mobile Header -->
    <nav class="navbar pmds-navbar sticky-top">
        <div class="container-fluid">
            <button class="btn btn-sm btn-light"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#mobileSidebar"
                    aria-controls="mobileSidebar">
                <i class="bi bi-list"></i>
            </button>

            <a class="navbar-brand ms-2" asp-controller="Inspection" asp-action="Index">ECRS-稽查系統</a>

            <div class="d-flex align-items-center gap-2 ms-auto">
                @if (!string.IsNullOrWhiteSpace(token))
                {
                    <span class="navbar-text d-none d-sm-inline">Hi, @displayName</span>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-light">登出</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-light" asp-controller="Auth" asp-action="Login">登入</a>
                }
            </div>
        </div>
    </nav>

    <!-- Offcanvas Sidebar：選單內容 = 原本 sidebar -->
    <div class="offcanvas offcanvas-start pmds-sidebar" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title text-white" id="mobileSidebarLabel">功能選單</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>

        <div class="offcanvas-body">

            <div class="auth-box mb-2">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div style="font-size:12px; color:floralwhite">已登入  @User.Identity!.Name</div>
                }
                else
                {
                    <a class="btn btn-sm btn-light w-100" asp-controller="Auth" asp-action="Login">登入</a>
                }
            </div>

            <ul class="nav nav-pills flex-column">

                <li class="@(isInspection ? "active" : "")">
                    <a class="nav-link" asp-controller="Inspection" asp-action="Index">稽查管理</a>

                    <div class="collapse @(isInspection ? "show" : "")">
                        <ul class="nav nav-pills flex-column pmds-submenu">
                            <li class="@(isInspectionWork ? "active" : "")">
                                <a class="nav-link" asp-controller="Inspection" asp-action="InspectionQry">稽查作業</a>
                            </li>
                            <li class="@(isInspectionVendor ? "active" : "")">
                                <a class="nav-link" asp-controller="Inspection" asp-action="Fquery">業者稽查查詢</a>
                            </li>
                            <li class="@(isInspectionCase ? "active" : "")">
                                <a class="nav-link" asp-controller="Inspection" asp-action="FormQuery">稽查單查詢</a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="@(isInspectionPReview ? "active" : "")">
                    <a class="nav-link" asp-controller="Inspection" asp-action="PReview">待審核案件</a>
                </li>

                <li class="@(isFormManage ? "active" : "")">
                    <a class="nav-link" asp-controller="FormManage" asp-action="Index">表單管理</a>

                    <div class="collapse @(isFormManage ? "show" : "")">
                        <ul class="nav nav-pills flex-column pmds-submenu">
                            <li class="@(isFormManageFormEditer ? "active" : "")">
                                <a class="nav-link" asp-controller="FormManage" asp-action="FormEditer">表單編輯作業</a>
                            </li>
                            <li class="@(isFormManageFormQryByPJ ? "active" : "")">
                                <a class="nav-link" asp-controller="FormManage" asp-action="FormQryByPJ">專案查詢</a>
                            </li>
                        </ul>
                    </div>
                </li>

            </ul>

        </div>
    </div>

    <!-- Content -->
    <main class="container-fluid py-2">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="pmds-footer">
        <div class="container text-center">
            建議使用 Edge或Chrome版本之瀏覽器，螢幕解析度1024X768以上瀏覽 衛生福利部食品藥物管理署 ©2022-2030 版權所有​<br />
            諮詢服務專線 : 0809-091-133 諮詢服務時間 : 08:00~12:00及13:00~18:00 (周一至周五)​elitech
        </div>
    </footer>

    <!-- 你既有 JS（視需求保留） -->
    <script src="~/inc/plugin/bootstrap-select/js/bootstrap-select.min.js" asp-append-version="true"></script>
    <script src="~/inc/plugin/owl-carousel/owl.carousel.js" asp-append-version="true"></script>
    <script src="~/inc/js/base.js" asp-append-version="true"></script>

    <script src="~/js/layout_site.js" asp-append-version="true"></script>
    <script src="~/js/FormManage/FormQryByPJ_site.js" asp-append-version="true"></script>
    <script src="~/js/FormManage/Formadd_note.js" asp-append-version="true"></script>
    <script src="~/js/Inspection/FormQuery_site.js" asp-append-version="true"></script>
    <script src="~/js/Inspection/PReview_site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>