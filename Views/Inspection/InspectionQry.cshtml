@{
    ViewData["Title"] = "稽查管理-稽查作業";
}

<h1 class="main-title">
    <span id="ctl00_ContentPlaceHolder1_UC_NodeName_lblNodeName">@ViewData["Title"]</span>
</h1>

<!-- 新增表單區塊 -->
<div class="card mt-3" id="formSelectPanel">

    <!-- Header -->
    <div class="card-header text-white" style="background:darkgreen;">
        新增表單
    </div>

    <div class="card-body">

        <!-- 查詢列 -->
        <div class="d-flex mb-3 align-items-center">
            <input type="text"
                   id="txtFormSearch"
                   class="form-control me-2"
                   placeholder="請輸入表單名稱">

            <a class="btn btn-primary text-nowrap"
               style="min-width:100px"
               asp-controller="Inspection"
               asp-action="InspectionQry">
                查詢表單
            </a>
        </div>


        <!-- 表單清單 -->
        <div class="border rounded p-3"
             style="background:#d9e3e6">

            <!-- 已勾選 -->
            <div class="form-check mb-2">
                <input class="form-check-input"
                       type="checkbox"
                       checked
                       id="form1">
                <label class="form-check-label">
                    114年度肉類加工食品食品安全監測計畫表
                </label>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       checked
                       id="form2">
                <label class="form-check-label">
                    餐飲業食品良好衛生規範準則 稽查紀錄表
                </label>
            </div>


            <!-- 未勾選 -->
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="form3">
                <label class="form-check-label">
                    GHP稽查紀錄表
                </label>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="form4">
                <label class="form-check-label">
                    HACCP稽查紀錄表
                </label>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="form5">
                <label class="form-check-label">
                    抽驗紀錄表
                </label>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="form6">
                <label class="form-check-label">
                    健康食品製造良好作業規範稽查表
                </label>
            </div>

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="form7">
                <label class="form-check-label">
                    其他
                </label>
            </div>

        </div>

        <!-- 功能列 - 確定 -->
        <div class="rounded p-1 d-flex mt-3 align-items-center justify-content-center w-100">

            <a class="btn btn-primary text-nowrap"
               style="min-width:100px"
               asp-controller="Inspection"
               asp-action="InspectionForms">
                確定
            </a>
         </div>
    </div>
</div>