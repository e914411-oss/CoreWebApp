@{
    // ViewData["Title"] = "稽查管理-稽查單查詢內容";
    ViewData["Title"] = "稽查管理 - 稽查作業 - 表單：餐飲業 食品良好衛生規範準則 稽查記錄表";
}

@section Styles {
    <style>
        .div-result {
            border: 1px solid #9fbea4;
            height: 120px;
            margin: 16px 0 16px 0;
        }

        .span-title-l2 {
            color: forestgreen;
        }

        .inspect-tab-wrap {
            width: 100%;
            margin: 16px 0;
        }

        .inspect-tab-header {
            display: flex;
            width: 100%;
            border: 1px solid #9fbea4;
            border-radius: 12px 12px 0 0;
            overflow: hidden;
            background: linear-gradient(to bottom, #eef7ef 0%, #dcebdd 100%);
        }

        .inspect-tab-btn {
            position: relative;
            flex: 1;
            height: 46px;
            border: 0;
            background: linear-gradient(to bottom, #eef7ef 0%, #dcebdd 100%);
            color: #6f9674;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s ease;
            border-right: 1px solid #b9d0bc;
        }

            .inspect-tab-btn:last-child {
                border-right: none;
            }

            /* 被選擇的 Tag */
            .inspect-tab-btn.active {
                color: #ffffff;
                background: linear-gradient(to bottom, #006400 0%, #005400 100%);
                box-shadow: inset 0 -2px 0 rgba(255,255,255,.12);
            }

                /* 底下小三角 */
                .inspect-tab-btn.active::after {
                    content: "";
                    position: absolute;
                    left: 50%;
                    bottom: -1px;
                    transform: translateX(-50%);
                    width: 0;
                    height: 0;
                    border-left: 10px solid transparent;
                    border-right: 10px solid transparent;
                    border-top: 10px solid #005400;
                }

            /* 未被選擇的 hover */
            .inspect-tab-btn:not(.active):hover {
                background: linear-gradient(to bottom, #e4f1e6 0%, #d2e4d4 100%);
                color: #4f7f56;
            }

        .inspect-tab-panel {
            display: none;
        }

            .inspect-tab-panel.active {
                display: block;
            }


        .photo-upload-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 18px;
        }

        .photo-upload-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            height: 46px;
            padding: 0 18px;
            /* border: 2px solid #9fd3d8; */
            border: 2px solid forestgreen;
            border-radius: 999px;
            background: linear-gradient(to bottom, #f9ffff 0%, #edf8f9 100%);
            /* color: #3aa8b3; */
            color: forestgreen;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s ease;
        }

            .photo-upload-pill:hover {
                background: linear-gradient(to bottom, #eefbfc 0%, #e2f3f5 100%);
                border-color: #86c4cb;
                color: #2f97a2;
            }

        .photo-upload-pill-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            font-size: 15px;
            color: forestgreen;
        }

        .photo-upload-section {
            margin-bottom: 20px;
        }

        .photo-upload-title {
            font-size: 16px;
            font-weight: 700;
            color: green;
            margin-bottom: 8px;
        }


        .inspection-file-list {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 12px;
            align-items: flex-start;
        }

        .inspection-file-chip {
            display: flex;
            align-items: center;
            min-width: 320px;
            max-width: 460px;
            height: 48px;
            border: 1px solid #d7e0e3;
            border-radius: 8px;
            overflow: hidden;
        }

        .inspection-file-title {
            flex: 0 0 100%;
            margin: 0 0 8px 0;
            color: forestgreen;
        }

        .attach-tab-wrap {
            background: #eef7ef;
            padding: 10px 0 12px 0;
        }

        .attach-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            padding: 0 12px 10px 12px;
        }

        .attach-pill-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            height: 42px;
            padding: 0 18px;
            /* border: 2px solid #71c1cc; */
            border: 2px solid forestgreen;
            border-radius: 999px;
            background: linear-gradient(to bottom, #fbffff 0%, #edf7f8 100%);
            /* color: #39a7b3; */
            color:forestgreen;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s ease;
        }

            .attach-pill-btn:hover {
                /* background: linear-gradient(to bottom, #f0fbfc 0%, #e2f2f4 100%); */
                background: linear-gradient(to bottom, #F0FFF0 0%, #CEFFCE 100%);
                color: forestgreen;
                border-color: forestgreen;
            }

        .attach-pill-icon {
            font-size: 14px;
            color: forestgreen;
        }

        .attach-section-card {
            margin: 0 12px 12px 12px;
            background: #fff;
            border: 1px solid #b8d1d7;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
        }

        .attach-section-title {
            padding: 10px 14px;
            font-size: 18px;
            font-weight: 700;
            color: #5b5b5b;
            border-bottom: 1px solid #e3ecef;
            background: #fff;
        }

        .attach-file-row {
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            padding: 14px;
        }

        .attach-file-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .attach-file-main {
            display: flex;
            align-items: center;
            min-width: 170px;
        }

        .attach-file-icon {
            width: 40px;
            height: 48px;
            border-radius: 4px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            flex-shrink: 0;
            margin-right: 10px;
            box-shadow: 0 1px 2px rgba(0,0,0,.12);
        }

            .attach-file-icon.pdf {
                background: #d92c2c;
            }

            .attach-file-icon.word {
                background: #2b66c0;
            }

            .attach-file-icon.excel {
                background: #1f8a49;
            }

        .attach-file-meta {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .attach-file-name {
            font-size: 16px;
            font-weight: 700;
            color: #66b7c0;
            line-height: 1.2;
        }

        .attach-file-size {
            font-size: 14px;
            color: #b4b4b4;
        }

        .attach-file-remove {
            width: 34px;
            height: 34px;
            border: 1px solid #dbdbdb;
            border-radius: 50%;
            background: #f9f9f9;
            color: #9c9c9c;
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
            padding: 0;
        }

            .attach-file-remove:hover {
                background: #f1f1f1;
                color: #6f6f6f;
            }

        .attach-save-row {
            display: flex;
            justify-content: flex-end;
            padding: 0 14px 14px 14px;
        }

        .attach-save-btn {
            min-width: 92px;
            height: 40px;
            border: 0;
            border-radius: 24px;
            /* background: linear-gradient(to bottom, #19a6b3 0%, #0d93a2 100%); */
            background: linear-gradient(to bottom, forestgreen 0%, darkgreen 100%);
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            box-shadow: 0 2px 4px rgba(0,0,0,.12);
        }

            .attach-save-btn:hover {
                /* background: linear-gradient(to bottom, #1597a3 0%, #0a8592 100%); */
                background: linear-gradient(to bottom, #00EC00 0%, forestgreen 100%);
            }

        @@media (max-width: 992px) {
            .attach-file-row {
                gap: 12px;
            }

            .attach-file-item {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
}


