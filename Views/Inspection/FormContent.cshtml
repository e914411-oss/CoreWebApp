@{
    ViewData["Title"] = "稽查管理-稽查單查詢內容";
}

@section Styles {
    <style>
        .inspect-tab-wrap {
            width: 100%;
            margin: 16px 0;
        }

        .inspect-tab-header {
            display: flex;
            width: 100%;
            border: 1px solid #9fbea4;
            border-radius: 12px 12px 0 0;
            overflow: hidden;
            background: linear-gradient(to bottom, #eef7ef 0%, #dcebdd 100%);
        }

        .inspect-tab-btn {
            position: relative;
            flex: 1;
            height: 46px;
            border: 0;
            background: linear-gradient(to bottom, #eef7ef 0%, #dcebdd 100%);
            color: #6f9674;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s ease;
            border-right: 1px solid #b9d0bc;
        }

            .inspect-tab-btn:last-child {
                border-right: none;
            }

            /* 被選擇的 Tag */
            .inspect-tab-btn.active {
                color: #ffffff;
                background: linear-gradient(to bottom, #006400 0%, #005400 100%);
                box-shadow: inset 0 -2px 0 rgba(255,255,255,.12);
            }

                /* 底下小三角 */
                .inspect-tab-btn.active::after {
                    content: "";
                    position: absolute;
                    left: 50%;
                    bottom: -1px;
                    transform: translateX(-50%);
                    width: 0;
                    height: 0;
                    border-left: 10px solid transparent;
                    border-right: 10px solid transparent;
                    border-top: 10px solid #005400;
                }

            /* 未被選擇的 hover */
            .inspect-tab-btn:not(.active):hover {
                background: linear-gradient(to bottom, #e4f1e6 0%, #d2e4d4 100%);
                color: #4f7f56;
            }

        .inspect-tab-panel {
            display: none;
        }

            .inspect-tab-panel.active {
                display: block;
            }


        .photo-upload-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 18px;
        }

        .photo-upload-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            height: 46px;
            padding: 0 18px;
            border: 2px solid #9fd3d8;
            border-radius: 999px;
            background: linear-gradient(to bottom, #f9ffff 0%, #edf8f9 100%);
            /* color: #3aa8b3; */
            color:forestgreen;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s ease;
        }

            .photo-upload-pill:hover {
                background: linear-gradient(to bottom, #eefbfc 0%, #e2f3f5 100%);
                border-color: #86c4cb;
                color: #2f97a2;
            }

        .photo-upload-pill-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            font-size: 15px;
            color: #7dbfc7;
        }

        .photo-upload-section {
            margin-bottom: 20px;
        }

        .photo-upload-title {
            font-size: 16px;
            font-weight: 700;
            color: #4d7074;
            margin-bottom: 8px;
        }


        .inspection-file-list {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 12px;
            align-items: flex-start;
        }

        .inspection-file-chip {
            display: flex;
            align-items: center;
            min-width: 320px;
            max-width: 460px;
            height: 48px;
            border: 1px solid #d7e0e3;
            border-radius: 8px;
            overflow: hidden;
        }
    </style>
}


<h1 class="main-title">
    <span id="ctl00_ContentPlaceHolder1_UC_NodeName_lblNodeName">@ViewData["Title"]</span>
</h1>

<!-- 上方切換頁籤 -->
<div class="inspect-tab-wrap">
    <div class="inspect-tab-header">
        <button type="button" class="inspect-tab-btn active" data-tab="tab-result">
            稽查結果
        </button>
        <button type="button" class="inspect-tab-btn" data-tab="tab-photo">
            照片
        </button>
        <button type="button" class="inspect-tab-btn" data-tab="tab-attach">
            附件
        </button>
    </div>

    <div class="inspect-tab-body">
        <!-- 稽查結果 -->
        <div id="tab-result" class="inspect-tab-panel active">
            <div class="p-3">
                這裡放「稽查結果」內容
            </div>
        </div>
        <!-- 照片 -->
        <div id="tab-photo" class="inspect-tab-panel">
            <div class="p-3">

                <div class="photo-upload-toolbar">
                    <button type="button" class="photo-upload-pill" onclick="triggerUpload('photoViolationInput')">
                        <span class="photo-upload-pill-icon">⇪</span>
                        <span>缺失/違規照片</span>
                    </button>

                    <button type="button" class="photo-upload-pill" onclick="triggerUpload('photoVestInput')">
                        <span class="photo-upload-pill-icon">⇪</span>
                        <span>稽查背心照片</span>
                    </button>

                    <button type="button" class="photo-upload-pill" onclick="triggerUpload('photoSampleInput')">
                        <span class="photo-upload-pill-icon">⇪</span>
                        <span>抽驗產品照片</span>
                    </button>

                    <button type="button" class="photo-upload-pill" onclick="triggerUpload('photoOtherInput')">
                        <span class="photo-upload-pill-icon">⇪</span>
                        <span>其他</span>
                    </button>
                </div>

                <!-- 隱藏的 input -->
                <input type="file" id="photoViolationInput" class="d-none" multiple accept="image/*" onchange="renderFiles(this, 'photoViolationList')" />
                <input type="file" id="photoVestInput" class="d-none" multiple accept="image/*" onchange="renderFiles(this, 'photoVestList')" />
                <input type="file" id="photoSampleInput" class="d-none" multiple accept="image/*" onchange="renderFiles(this, 'photoSampleList')" />
                <input type="file" id="photoOtherInput" class="d-none" multiple accept="image/*" onchange="renderFiles(this, 'photoOtherList')" />

                <!-- 各類照片清單 -->
                <div class="photo-upload-section">
                    <div class="photo-upload-title">缺失/違規照片</div>
                    <div class="inspection-file-list" id="photoViolationList"></div>
                </div>

                <div class="photo-upload-section">
                    <div class="photo-upload-title">稽查背心照片</div>
                    <div class="inspection-file-list" id="photoVestList"></div>
                </div>

                <div class="photo-upload-section">
                    <div class="photo-upload-title">抽驗產品照片</div>
                    <div class="inspection-file-list" id="photoSampleList"></div>
                </div>

                <div class="photo-upload-section">
                    <div class="photo-upload-title">其他</div>
                    <div class="inspection-file-list" id="photoOtherList"></div>
                </div>

            </div>
        </div>
        <!-- 附件 -->
        <div id="tab-attach" class="inspect-tab-panel">
            <div class="p-3">
                這裡放「附件」內容
                <div class="inspection-file-list" id="evidenceFileList1">
                    <div class="inspection-file-chip">
                        <span class="inspection-file-icon">📄</span>
                        <span class="inspection-file-name">c738a344ec0c4b87ab020d0c59051165.docx</span>
                    </div>

                    <div class="inspection-file-chip">
                        <span class="inspection-file-icon">📄</span>
                        <span class="inspection-file-name">5ea211be46474d4db8bcbc87e72e7a794c.docx</span>
                    </div>

                    <div class="inspection-file-chip">
                        <span class="inspection-file-icon">📄</span>
                        <span class="inspection-file-name">8b301509d0fa4d3d8cf770c4ddd1cbaf.docx</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabButtons = document.querySelectorAll('.inspect-tab-btn');
            const tabPanels = document.querySelectorAll('.inspect-tab-panel');

            tabButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-tab');

                    tabButtons.forEach(x => x.classList.remove('active'));
                    tabPanels.forEach(x => x.classList.remove('active'));

                    this.classList.add('active');

                    const panel = document.getElementById(targetId);
                    if (panel) {
                        panel.classList.add('active');
                    }
                });
            });
        });
    </script>
}