@{
    ViewData["Title"] = "稽查管理-稽查作業-表單：餐飲業 食品良好衛生規範準則 稽查記錄表";
}

@section Styles {
    <style>
        .inspection-question-panel {
            margin-top: 24px;
        }

        .inspection-question-card {
            background: #f7f8f8;
            border: 1px solid #dfe5e7;
            border-radius: 12px;
            padding: 18px 18px 14px 18px;
            margin-bottom: 18px;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
        }

        .inspection-question-title {
            font-size: 18px;
            font-weight: 700;
            color: #222;
            line-height: 1.8;
            margin-bottom: 14px;
        }

        .inspection-question-body {
            background: #fff;
            border: 1px solid #e2e7ea;
            border-radius: 10px;
            padding: 14px;
        }

        .inspection-result-row {
            margin-bottom: 14px;
        }

        .inspection-result-select {
            height: 44px;
            border-radius: 8px;
            border: 1px solid #d6dde2;
            font-size: 16px;
            color: #444;
        }

        .inspection-upload-row {
            margin-bottom: 12px;
        }

        .inspection-upload-btn {
            min-width: 150px;
            height: 44px;
            border-radius: 24px;
            /* border: 2px solid #b9dfe2; */
            border: 2px solid forestgreen;
            background: #f8ffff;
            /* color: #69b8bd; */
            color: forestgreen;
            font-size: 16px;
            font-weight: 700;
            padding: 0 20px;
        }

            .inspection-upload-btn:hover {
                background: #eefbfc;
                color: darkgreen;
                border-color: darkgreen;
            }

        .inspection-file-list {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .inspection-file-chip {
            display: flex;
            align-items: center;
            min-width: 320px;
            max-width: 460px;
            height: 48px;
            border: 1px solid #d7e0e3;
            border-radius: 8px;
            background: #fff;
            overflow: hidden;
        }

        .inspection-file-icon {
            width: 44px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eef6f7;
            font-size: 20px;
            flex-shrink: 0;
        }

        .inspection-file-name {
            flex: 1;
            padding: 0 12px;
            font-size: 15px;
            color: #6aaeb5;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .inspection-file-remove {
            width: 40px;
            height: 48px;
            border: 0;
            background: transparent;
            color: #87b9be;
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
            flex-shrink: 0;
        }

            .inspection-file-remove:hover {
                color: #4d8d93;
            }

        @@media (max-width: 992px) {
            .inspection-question-title {
                font-size: 16px;
            }

            .inspection-file-chip {
                min-width: 100%;
                max-width: 100%;
            }
        }

        .inspection-group {
            width: 100%;
        }

        .inspection-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 8px;
            margin-bottom: 1px;
            white-space: normal;
        }

        .check-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin: 0;
            white-space: normal;
            font-weight: normal;
        }

            .check-item input[type="checkbox"] {
                margin: 0;
            }

        .date-input {
            width: 80px;
            display: inline-block;
        }

        .note-input {
            width: 240px;
            display: inline-block;
        }

        .rule-text {
            display: block;
            width: 100%;
            margin-bottom: 8px;
            line-height: 1.8;
            word-break: break-word;
            overflow-wrap: break-word;
            white-space: pre-line;
        }

        .pmds-radio-group {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

            .pmds-radio-group .radio-inline-item {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                margin-top: 6px;
                white-space: nowrap;
                font-weight: normal;
            }

                .pmds-radio-group .radio-inline-item input[type="radio"] {
                    margin: 0;
                }

        .btn-primary-line {
            height: 24px;
            padding: 1px 8px 0 8px;
            box-sizing: border-box;
        }
    </style>
}


<h1 class="main-title">
