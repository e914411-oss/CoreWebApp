@section Styles {
    <style>
        .pmds-radio-group {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

            .pmds-radio-group .radio-inline-item {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                margin-top: 6px;
                white-space: nowrap;
                font-weight: normal;
            }

                .pmds-radio-group .radio-inline-item input[type="radio"] {
                    margin: 0;
                }

        .Formang-question-body {
            background: #fff;
            border: 1px solid #e2e7ea;
            border-radius: 10px;
            padding: 14px;
        }

        .Formang-group {
            width: 100%;
        }

        .Formang-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
            white-space: normal;
        }
    </style>
}

