@{
    ViewData["Title"] = "新增/編輯表單";
    string? formName = ViewData["FormName"] as string;
    string strFormName = string.IsNullOrEmpty(formName) ? string.Empty : formName;

    @Html.AntiForgeryToken()
    ;
}

@section Styles {
    <style>
        .pmds-radio-group {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

            .pmds-radio-group .radio-inline-item {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                margin-top: 2px;
                white-space: nowrap;
                font-weight: normal;
            }

                .pmds-radio-group .radio-inline-item input[type="radio"] {
                    margin: 0;
                }

        .radio-inline {
            margin-top:6px;
        }

        .btn-primary-line {
            height: 24px;
            padding: 0 8px 0 8px;
            box-sizing: border-box;
        }
    </style>
}

<div class="content" style="min-height: 561px;">
    <h1 class="main-title">
        <span id="ctl00_ContentPlaceHolder1_UC_NodeName_lblNodeName">@ViewData["Title"]</span>
    </h1>
    <div class="edit-form">
        <div class="tb-single-rwd">
            <div class="td hd"><span style="color: Red">＊</span>表單名稱：</div>
            <div class="td">
                <input id="FormName" class="form-control" type="text" style="width:100%;" value=@strFormName>
            </div>
            <div class="td">
            </div>
        </div>

        <div class="tb-single-rwd">
            <div class="td hd"><span id="span_Testing_Weight" style="color: Red;"></span>專案截止日期：</div>
            <div class="td">
                <div class="input-group date">
                    <input name="ctl00$ContentPlaceHolder1$txt_ProjectYear" type="text" id="ctl00_ContentPlaceHolder1_txt_ProjectYear" class="datepicker form-control">
                    <div class="input-group-addon" onclick="$(this).prev().focus()">
                        <i class="icon-calendar-full"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="tb-single-rwd" ui-id="CheckMenu">
            <div class="td hd"><span style="color: Red">＊</span>稽查項目：</div>
            <div class="td">
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk1" type="checkbox" value="Y">
                        <span>GHP</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk2" type="checkbox" value="Y">
                        <span>食品業者登錄</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk3" type="checkbox" value="Y">
                        <span>產品責任險</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk4" type="checkbox" value="Y">
                        <span>HACCP</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk5" type="checkbox" value="Y">
                        <span>保存來源文件</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk6" type="checkbox" value="Y">
                        <span>追溯追蹤</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk7" type="checkbox" value="Y">
                        <span>一級品管</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk8" type="checkbox" value="Y">
                        <span>逾期食品</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk9" type="checkbox" value="Y">
                        <span>衛生管理人員</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk10" type="checkbox" value="Y">
                        <span>專門職業或技術證照人員查核</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk11" type="checkbox" value="Y">
                        <span>定型化契約</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk12" type="checkbox" value="Y">
                        <span>標示</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk13" type="checkbox" value="Y">
                        <span>抽驗</span>
                    </label>

                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk14" type="checkbox" value="Y">
                        <span>查驗登記工廠</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="chk15" type="checkbox" value="Y">
                        <span>查驗登記產品</span>
                    </label>
                </div>
                <div class="pmds-radio-group">
                    <input type="button" class="btn btn-primary-line" id="FormAdd_Note" value="備註" />
                </div>
            </div>
        </div>
        <div class="tb-single-rwd">
            <div class="td hd"><span style="color: Red">＊</span>自訂欄位：</div>
            <div class="td">
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="rdoSelfSetYes" type="radio" name="IsSelfSet" value="Y" checked="checked">
                        <span>是</span>
                    </label>
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="rdoSelfSetYes" type="radio" name="IsSelfSet" value="N">
                        <span>否</span>
                    </label>
                    <input type="button" class="btn btn-primary-line" id="btnSetItem" value="設定" />
                </div>
            </div>
        </div>
        <div class="tb-single-rwd">
            <div class="td hd">狀態：</div>
            <div class="td">
                <div class="pmds-radio-group">
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="rdoSelfSetStatus" type="radio" name="IsSetStatus" value="Y" checked="checked">
                        <span>是</span>
                    </label>
                    <label class="radio-inline-item" for="ctl00_ContentPlaceHolder1_rbtnListProjectStatus_0">
                        <input id="rdoSelfSetStatus" type="radio" name="IsSetStatus" value="N">
                        <span>否</span>
                    </label>
                </div>
            </div>
        </div>
    </div>
    <div class="btn-area">
        <button type="button" class="btn btn-primary" onclick="window.history.go(-1);">取消</button>
        @* <input type="submit" name="ctl00$ContentPlaceHolder1$btnCancle" value="取消" id="ctl00_ContentPlaceHolder1_btnCancle" class="btn btn-primary"> *@
        <input type="submit" name="ctl00$ContentPlaceHolder1$btnSave" value="儲存" onclick="return CheckData();" id="ctl00_ContentPlaceHolder1_btnSave" class="btn btn-primary">
        <button type="button" class="btn btn-primary" onclick="window.history.go(-1);">預覽表單</button>
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_PPM" id="ctl00_ContentPlaceHolder1_hid_PPM">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_DRR_M" id="ctl00_ContentPlaceHolder1_hid_DRR_M">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_DRR_D" id="ctl00_ContentPlaceHolder1_hid_DRR_D">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_DRM" id="ctl00_ContentPlaceHolder1_hid_DRM">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_PPM_M" id="ctl00_ContentPlaceHolder1_hid_PPM_M">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_PPM_D" id="ctl00_ContentPlaceHolder1_hid_PPM_D">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid_ProjectYear" id="ctl00_ContentPlaceHolder1_hid_ProjectYear">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$DynamicItem" id="ctl00_ContentPlaceHolder1_DynamicItem">
        <input type="hidden" name="ctl00$ContentPlaceHolder1$hid專案空白欄位" id="ctl00_ContentPlaceHolder1_hid專案空白欄位">
    </div>
</div>

<!-- 備註遮罩 + 視窗 -->
<div id="noteOverlay" class="pmds-overlay" style="display:none;">
    <div class="pmds-note-modal" role="dialog" aria-modal="true" aria-labelledby="noteTitle">
        <div class="pmds-note-header">
            <span id="noteTitle" class="pmds-note-title">一級品管 - 備註</span>
        </div>

        <div class="pmds-note-body">
            <textarea id="noteText" style="height:300px" class="form-control pmds-note-textarea" placeholder="" maxlength="500"></textarea>
        </div>

        <div class="pmds-note-footer">
            <button type="button" id="noteCancelBtn" class="btn btn-success">取消</button>
            <button type="button" id="noteOkBtn" class="btn btn-success">確定</button>
        </div>
    </div>
</div>

<!-- 設定遮罩 + 視窗 -->
<div id="SetItemOverlay" class="pmds-overlay" style="display:none;">
    <div class="pmds-note-modal" role="dialog" aria-modal="true" aria-labelledby="noteTitle">
        <div class="pmds-note-header">
            <span id="noteTitle" class="pmds-note-title">編輯浮動欄位</span>
        </div>
        <div class="pmds-note-body">
            <div>
                <div id="ctl00_ContentPlaceHolder1_Panel_menu" class="form-control pmds-note-textarea" placeholder="" maxlength="500">

                    <menu ui-id="menu" ui-action="Add">
                        <div class="tb-single-rwd">
                            <div class="td hd"><span style="color: Red">＊</span>排序：​</div>
                            <div class="td">
                                <input name="ctl00$ContentPlaceHolder1$txt_Sort" type="text" id="ctl00_ContentPlaceHolder1_txt_Sort" class="form-control" ui-id="txt_Sort" input-type="numeric" reset-type="txt" style="width:100px;">
                            </div>
                        </div>
                        <div class="tb-single-rwd">
                            <div class="td hd"><span style="color: Red">＊</span>標題：​</div>
                            <div class="td">
                                <input name="ctl00$ContentPlaceHolder1$TextBox1" type="text" maxlength="50" id="ctl00_ContentPlaceHolder1_TextBox1" class="form-control" ui-id="txtTitle" reset-type="txt" style="width: 80%;">
                            </div>
                        </div>
                        <div class="tb-single-rwd">
                            <div class="td hd">說明：​</div>
                            <div class="td">
                                <input name="ctl00$ContentPlaceHolder1$txtIllustrate" type="text" maxlength="200" id="ctl00_ContentPlaceHolder1_txtIllustrate" class="form-control" ui-id="txtIllustrate" reset-type="txt" style="width: 80%;">
                            </div>
                        </div>
                        <div class="tb-single-rwd">
                            <div class="td hd">
                                <span style="color: Red">＊</span>類型：
                            </div>
                            <div class="td">
                                <div class="pmds-radio-group">
                                    <span class="radio-inline"><input id="ctl00_ContentPlaceHolder1_rblReported_Type_0" type="radio" name="ctl00$ContentPlaceHolder1$rblReported_Type" value="int"><label for="ctl00_ContentPlaceHolder1_rblReported_Type_0">數字</label></span>
                                    <span class="radio-inline"><input id="ctl00_ContentPlaceHolder1_rblReported_Type_1" type="radio" name="ctl00$ContentPlaceHolder1$rblReported_Type" value="txt"><label for="ctl00_ContentPlaceHolder1_rblReported_Type_1">文字</label></span>
                                </div>
                            </div>
                        </div>
                        <div class="tb-single-rwd">
                            <div class="td hd"><span style="color: Red">＊</span>必填：</div>
                            <div class="td">
                                <div class="pmds-radio-group">
                                    <span class="radio-inline"><input id="ctl00_ContentPlaceHolder1_rblReported_Type_0" type="radio" name="ctl00$ContentPlaceHolder1$rblReported_Type" value="int"><label for="ctl00_ContentPlaceHolder1_rblReported_Type_0">數字</label></span>
                                    <span class="radio-inline"><input id="ctl00_ContentPlaceHolder1_rblReported_Type_1" type="radio" name="ctl00$ContentPlaceHolder1$rblReported_Type" value="txt"><label for="ctl00_ContentPlaceHolder1_rblReported_Type_1">文字</label></span>
                                </div>
                            </div>
                        </div>
                        <div class="btn-area">
                            <div ui-id="newbtnG">
                                <input type="button" class="btn btn-primary" name="ctl00$ContentPlaceHolder1$btnNewDynamic" value="儲存" onclick="return false;" id="ctl00_ContentPlaceHolder1_btnNewDynamic" class="btn btn-sm btn-default" ui-id="btnNewDynamic">
                                &nbsp;
                                <input type="button" class="btn btn-primary" name="ctl00$ContentPlaceHolder1$btnResetDynamic1" value="取消" onclick="return false;" id="ctl00_ContentPlaceHolder1_btnResetDynamic1" class="btn btn-sm btn-default" ui-id="btnResetDynamic1">
                            </div>
                            <div ui-id="updbtnG" style="display: none;">
                                <input type="button" class="btn btn-primary" name="ctl00$ContentPlaceHolder1$btnSaveDynamic" value="儲存" onclick="return false;" id="ctl00_ContentPlaceHolder1_btnSaveDynamic" class="btn btn-sm btn-default" ui-id="btnSaveDynamic">
                                &nbsp;
                                <input type="button" class="btn btn-primary" name="ctl00$ContentPlaceHolder1$btnResetDynamic2" value="取消" onclick="return false;" id="ctl00_ContentPlaceHolder1_btnResetDynamic2" class="btn btn-sm btn-default" ui-id="btnResetDynamic2">
                            </div>
                        </div>
                    </menu>

                </div>
                <div style="text-align: right">
                    <input type="button" class="btn btn-primary" name="ctl00$ContentPlaceHolder1$btnShowMenu" value="新增項目" onclick="return false;" id="ctl00_ContentPlaceHolder1_btnShowMenu" ui-id="btnShowMenu">
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .pmds-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pmds-note-modal {
        width: min(980px, 92vw);
        height: min(620px, 82vh);
        background: #fff;
        border-radius: 4px;
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 1px solid #ddd;
    }

    .pmds-note-header {
        padding: 14px 18px;
        background: #eaf6ea;
        border-bottom: 1px solid #cfe6cf;
    }

    .pmds-note-title {
        color: #1a8f2b;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .pmds-note-body {
        padding: 18px;
        flex: 1;
    }

    .pmds-note-textarea {
        width: 100%;
        height: 100%;
        resize: none;
        border: 2px solid #e0e0e0;
        border-radius: 4px;
        padding: 12px;
        font-size: 16px;
        outline: none;
    }

    .pmds-note-footer {
        padding: 14px 18px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #eee;
        background: #fff;
    }
</style>

